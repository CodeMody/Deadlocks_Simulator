  Node1 [id="Node000001",label="Scheduler",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip="Interne Repräsentation des Schedulers."];
  Node2 -> Node1 [id="edge6_Node000001_Node000002",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">state</TD></TR>
</TABLE>> ,fontcolor="grey" ];
  Node2 [id="Node000002",label="SystemState",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$struct_system_state.html",tooltip="Zentraler Systemzustand des Ressourcen-Managers."];
  Node3 -> Node1 [id="edge7_Node000001_Node000003",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">policy</TD></TR>
</TABLE>> ,fontcolor="grey" ];
  Node3 [id="Node000003",label="Policy",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$struct_policy.html",tooltip="Policy-Objekt, das eine Deadlock-Behandlungsstrategie darstellt."];
  Node3 -> Node3 [id="edge8_Node000003_Node000003",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">cleanup</TD></TR>
<TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">on_request</TD></TR>
<TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">on_tick</TD></TR>
</TABLE>> ,fontcolor="grey" ];
  Node4 -> Node1 [id="edge9_Node000001_Node000004",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">heap</TD></TR>
</TABLE>> ,fontcolor="grey" ];
  Node4 [id="Node000004",label="EventHeap",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$struct_event_heap.html",tooltip="Interne Struktur des Ereignis-Heaps."];
  Node5 -> Node4 [id="edge10_Node000004_Node000005",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">data</TD></TR>
</TABLE>> ,fontcolor="grey" ];
  Node5 [id="Node000005",label="Event",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$struct_event.html",tooltip="Einzelnes Ereignis in der zeitgesteuerten Event-Queue."];
